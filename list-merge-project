def input_list():
    s = input("Введите числа через пробел: ")
    parts = s.split()
    result = []
for i in parts:
        if i.isdigit():
            result.append(int(i))
        else:
            print("Обнаружено не число, пропускаем:", i)

    return result
def merge_lists(a, b):
    return a + b
def merge_unique(a, b):
    result = []
    for i in a + b:
        if i not in result:
            result.append(i)
    return result
